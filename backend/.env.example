# Qdrant (the only server-side infra)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Nostr relays (comma-separated)
RELAY_URLS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.snort.social

# Pubkeys to index (comma-separated hex)
PUBKEYS=
# Display labels for pubkeys (JSON map)
PUBKEY_LABELS={}

# Blossom server data directory (for file watcher)
BLOSSOM_DATA_DIR=./data/blobs

# Collection and model settings
COLLECTION_NAME=nostr_rag
VECTOR_SIZE=1024
EMBEDDING_MODEL=mixedbread-ai/mxbai-embed-large-v1
MIN_CONTENT_LENGTH=50

# NOTE: API keys for AI services (HuggingFace, Anthropic, Groq, Gemini)
# are NOT stored here. Users provide their own keys via the frontend UI.
# Keys are sent per-request in HTTP headers (X-HF-Key, X-LLM-Key, etc.)
